{
	"name": "admin",
	"version": "0.1.12",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "dotenv -e .dev.env -- npm run dev:with-env",
		"dev:app": "vite --port 3101",
		"dev:with-env": "npm run docker:up && node scripts/ensure-dev-db.mjs && npm run s3:populate:dev && npm run dev:app",
		"dev:full": "npm run docker:up && npm run dev",
		"build": "vite build",
		"start": "node .output/server/index.mjs",
		"lint": "biome lint",
		"format": "biome format --write",
		"check": "biome check --write",
		"test": "dotenv -e .test.env -- npm run test:all",
		"test:all": "npm run test:unit && npm run test:e2e",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"coverage:all": "npm run coverage:unit && npm run coverage:e2e && npm run coverage:merge",
		"coverage:unit": "vitest run --coverage",
		"coverage:e2e": "playwright test --reporter=html",
		"coverage:merge": "node --import tsx ./tests/util/merge-coverage.mts",
		"docker:up": "docker compose -f ../../devops/docker-compose.yml up -d",
		"docker:down": "docker compose -f ../../devops/docker-compose.yml down",
		"db:populate:dev": "cd ../../data && cargo make mysql-populate-dev",
		"db:populate:dev:test-articles": "cd ../../data && cargo make mysql-populate-dev-with-test-articles",
		"db:populate:test": "cd ../../data && cargo make mysql-populate-test",
		"s3:populate:dev": "cd ../../data && cargo make s3-populate-dev",
		"s3:populate:test": "cd ../../data && cargo make s3-populate-test"
	},
	"engines": {
		"node": ">=24.11.1 <24.12.0"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1014.0",
		"@aws-sdk/s3-request-presigner": "3.1014.0",
		"@tanstack/react-query": "5.94.5",
		"@tanstack/react-router": "1.168.1",
		"@tanstack/react-router-devtools": "1.166.10",
		"@tanstack/react-start": "1.167.2",
		"@tiptap/extension-bullet-list": "2.27.2",
		"@tiptap/extension-image": "2.27.2",
		"@tiptap/extension-italic": "2.27.2",
		"@tiptap/extension-link": "2.27.2",
		"@tiptap/extension-list-item": "2.27.2",
		"@tiptap/extension-ordered-list": "2.27.2",
		"@tiptap/extension-placeholder": "2.27.2",
		"@tiptap/pm": "2.27.2",
		"@tiptap/react": "2.27.2",
		"@tiptap/starter-kit": "2.27.2",
		"flowbite": "4.0.1",
		"flowbite-react": "0.12.17",
		"gematry": "1.0.2",
		"jose": "6.2.2",
		"mysql2": "3.20.0",
		"nitro": "npm:nitro-nightly@3.0.1-20260320-182900-2218d454",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"uuid": "11.1.0",
		"vinxi": "0.5.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@playwright/test": "1.58.2",
		"@tailwindcss/vite": "4.2.2",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@types/uuid": "10.0.0",
		"@vitejs/plugin-react": "4.7.0",
		"@vitest/coverage-v8": "3.2.4",
		"autoprefixer": "10.4.27",
		"dotenv-cli": "7.4.4",
		"jsdom": "27.4.0",
		"postcss": "8.5.8",
		"tailwindcss": "4.2.2",
		"typescript": "5.9.3",
		"vite": "7.3.1",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "3.2.4"
	}
}
