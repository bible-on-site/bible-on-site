{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended", ":dependencyDashboard"],
	"packageRules": [
		{
			"matchUpdateTypes": ["minor", "patch", "pin", "digest"],
			"matchDepTypes": ["devDependencies"],
			"automerge": true
		},
		{
			"labels": ["linting"],
			"matchPackageNames": ["/eslint/", "/biome/"]
		},
		{
			"matchDepTypes": ["optionalDependencies"],
			"addLabels": ["optional"],
			"automerge": true
		},
		{
			"groupName": "all non-major dependencies",
			"groupSlug": "all-minor-patch",
			"matchPackageNames": ["*"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true
		},
		{
			"description": "See https://github.com/bible-on-site/bible-on-site/issues/528",
			"matchPackageNames": ["swc-plugin-coverage-instrument"],
			"enabled": false
		},
		{
			"description": "See https://github.com/bible-on-site/bible-on-site/issues/1634",
			"matchPackageNames": ["next"],
			"allowedVersions": "<16.2.0"
		},
		{
			"description": "See https://github.com/bible-on-site/bible-on-site/issues/1636",
			"matchPackageNames": ["sunrise-sunset-js"],
			"allowedVersions": "<3.3.0"
		},
		{
			"description": "See https://github.com/bible-on-site/bible-on-site/issues/985",
			"matchPackageNames": ["node"],
			"matchDepTypes": ["engines"],
			"allowedVersions": ">=24.11.1 <24.12.0"
		},
		{
			"description": "macos-26 breaks the .NET MAUI iOS build (default Xcode 26); see https://github.com/bible-on-site/bible-on-site/issues/1627",
			"matchManagers": ["github-actions"],
			"matchPackageNames": ["macos"],
			"allowedVersions": "<26"
		}
	],
	"bumpVersion": "patch",
	"vulnerabilityAlerts": {
		"automerge": true,
		"labels": ["security"],
		"groupName": null,
		"schedule": [],
		"dependencyDashboardApproval": false,
		"minimumReleaseAge": null,
		"rangeStrategy": "update-lockfile",
		"commitMessageSuffix": "[SECURITY]",
		"branchTopic": "{{{datasource}}}-{{{depName}}}-vulnerability",
		"prCreation": "immediate"
	},
	"labels": ["dependencies"]
}
